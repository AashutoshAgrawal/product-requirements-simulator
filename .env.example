# =============================================================================
# NEEDGEN - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Get your API key from: https://platform.openai.com/api-keys
# 3. Replace "your_api_key_here" with your actual key
# 4. Restart the backend after making changes
#
# SECURITY: Never commit .env to git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI API Key(s)
# -----------------------------------------------------------------------------
# Get your API keys from: https://platform.openai.com/api-keys
#
# For basic usage (1-5 agents), one key is sufficient:
OPENAI_API_KEY=your_api_key_here

# For scaling (10+ agents), add multiple keys for load balancing:
# The system automatically detects and distributes load across all numbered keys
# Uncomment and add your keys below:

# OPENAI_API_KEY_1=your_first_api_key_here
# OPENAI_API_KEY_1_NAME=Primary-General-Use

# OPENAI_API_KEY_2=your_second_api_key_here
# OPENAI_API_KEY_2_NAME=Agents-1-to-10-ProductReqs

# OPENAI_API_KEY_3=your_third_api_key_here
# OPENAI_API_KEY_3_NAME=Agents-11-to-20-UserExperience

# OPENAI_API_KEY_4=your_fourth_api_key_here
# OPENAI_API_KEY_4_NAME=Agents-21-to-30-NeedExtraction

# ... add more as needed (OPENAI_API_KEY_5, OPENAI_API_KEY_6, etc.)

# -----------------------------------------------------------------------------
# OPTIONAL: Logging Configuration
# -----------------------------------------------------------------------------
# Logging level: DEBUG (detailed), INFO (normal), WARNING (errors only)
# LOG_LEVEL=INFO

# Log to file (leave empty to log only to console)
# LOG_FILE=pipeline.log

# -----------------------------------------------------------------------------
# PRODUCTION: Frontend Configuration (for deployment only)
# -----------------------------------------------------------------------------
# Backend API URL for frontend to connect to
# Local development: http://localhost:8000
# Production: your Render/deployed backend URL
# REACT_APP_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# PRODUCTION: Render.com Configuration (for deployment only)
# -----------------------------------------------------------------------------
# These are set automatically by Render.com
# PORT=8000
# PYTHON_VERSION=3.11.0

# -----------------------------------------------------------------------------
# NAMING CONVENTION EXAMPLES for Multiple Keys:
# -----------------------------------------------------------------------------
# Organize your keys by purpose for easier management:
# - Primary-General-Use
# - Testing-Development
# - Agents-1-to-10-ProductReqs
# - Agents-11-to-20-UserExperience
# - Agents-21-to-30-NeedExtraction
# - HighVolume-Interview-Pipeline
# - Backup-Key-Emergency
# =============================================================================
